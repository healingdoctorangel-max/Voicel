<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="oval">
            <solid android:color="#1A1D27"/>
            <stroke android:width="1dp" android:color="#2A2D3A"/>
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#2A2D3A"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#22263A"/>
            <stroke android:width="1.5dp" android:color="#3A3F55"/>
        </shape>
    </item>
</selector>
